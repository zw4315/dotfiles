[user]
  name = Edward
  email = ed.z.wu@outlook.com

[core]
  autocrlf = input
  safecrlf = true
  whitespace = trailing-space,space-before-tab
  excludesfile = ~/.gitignore_global
	editor = vim

[init]
  defaultBranch = main

[push]
  default = simple
  autoSetupRemote = true

[pull]
  rebase = true

[fetch]
  prune = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = zebra

[color]
  ui = auto

[color "diff"]
  meta = 178 bold
  frag = 117 bold
  func = 252
  old = 203 bold
  new = 114 bold
  whitespace = reverse 203
  oldMoved = 203 bold
  oldMovedAlternative = 178 bold
  newMoved = 114 bold
  newMovedAlternative = 117 bold

[delta]
  syntax-theme = Monokai Extended Bright
  file-style = 178 bold
  hunk-header-style = 117 bold
  minus-style = 203 normal
  plus-style = 114 normal
  line-numbers-minus-style = 203 bold
  line-numbers-plus-style = 114 bold
  line-numbers-left-style = 203
  line-numbers-right-style = 114
  line-numbers-zero-style = 244

[alias]
  # Basic shortcuts
  st = status -sb
  co = checkout
  br = branch
  ci = commit
  cm = commit -m
  cp = cherry-pick

  # Log with graph
  lg = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
  lga = log --color --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --all

  # Diff
  d = diff
  dc = diff --cached
  ds = diff --stat

  # Undo helpers
  unstage = reset HEAD --
  uncommit = reset --soft HEAD^
  rsh = reset --soft HEAD^
  undo = checkout --

  # Branch management
  brm = branch --merged
  brnm = branch --no-merged
  brd = branch -d
  brD = branch -D

  # Stash
  sl = stash list
  sp = stash pop
  ss = stash save

[help]
  autocorrect = 20

[rerere]
  enabled = true
[include]
	path = ~/.gitconfig_local

[credential]
	helper = osxkeychain
