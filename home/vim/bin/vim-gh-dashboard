#!/usr/bin/env python3
"""Generate GitHub dashboard for Vim startify.

Shows:
- GitHub contribution heatmap (based on actual commits across all repos)
- Top 10 active repositories
- Recently updated repositories

Requires: gh CLI authenticated with GitHub
"""
import json
import subprocess
from concurrent.futures import ThreadPoolExecutor
from datetime import datetime, timedelta
from pathlib import Path


# ---------------------------------------------------------------------------
# Cache helpers
# ---------------------------------------------------------------------------
def get_daily_cache_path():
    cache_dir = Path.home() / ".cache"
    cache_dir.mkdir(exist_ok=True, parents=True)
    return cache_dir / "vim-gh-dashboard-daily.json"


def load_daily_cache():
    cache_file = get_daily_cache_path()
    if cache_file.exists():
        try:
            with open(cache_file) as f:
                return json.load(f)
        except Exception:
            return None
    return None


WEEKS_TO_SHOW = 20


def save_daily_cache(data, complete_through=None):
    cache_file = get_daily_cache_path()
    try:
        payload = {
            'last_updated': datetime.now().isoformat(),
            'version': 2,
            'data': data
        }
        if complete_through:
            payload['complete_through'] = complete_through
        with open(cache_file, 'w') as f:
            json.dump(payload, f)
    except Exception:
        pass


def is_today_cache(cache):
    if not cache or 'last_updated' not in cache:
        return False
    try:
        last_updated = datetime.fromisoformat(cache['last_updated'])
        return last_updated.date() == datetime.now().date()
    except Exception:
        return False


# ---------------------------------------------------------------------------
# Git identity (source of truth for author matching)
# ---------------------------------------------------------------------------
def get_git_identity():
    """Return (name, email) from git config."""
    name = "Edward"
    email = ""
    try:
        result = subprocess.run(
            ["git", "config", "user.name"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0:
            name = result.stdout.strip() or name
    except Exception:
        pass
    try:
        result = subprocess.run(
            ["git", "config", "user.email"],
            capture_output=True, text=True, timeout=5
        )
        if result.returncode == 0:
            email = result.stdout.strip()
    except Exception:
        pass
    return name, email


# ---------------------------------------------------------------------------
# Repo listing
# ---------------------------------------------------------------------------
def get_all_repos():
    result = subprocess.run([
        "gh", "repo", "list", "zw4315", "--limit", "100",
        "--json", "name,defaultBranchRef"
    ], capture_output=True, text=True)
    if result.returncode != 0:
        return []
    try:
        return json.loads(result.stdout)
    except Exception:
        return []


# ---------------------------------------------------------------------------
# Commit fetching (per repo) -> returns (dates, count)
# ---------------------------------------------------------------------------
def get_repo_commit_info(repo_name, since, until, git_name, git_email):
    cmd = [
        "gh", "api",
        f"repos/zw4315/{repo_name}/commits?since={since}&until={until}&per_page=100",
        "--paginate",
        "--jq",
        '.[] | {login: (.author.login // ""), name: .commit.author.name, email: .commit.author.email, date: .commit.author.date[:10]}',
    ]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        return [], 0

    dates = []
    git_name_lower = git_name.lower()
    for line in result.stdout.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError:
            continue
        login = obj.get("login") or ""
        name = obj.get("name") or ""
        email = obj.get("email") or ""
        name_lower = name.lower()

        # Multi-dimensional match: GitHub login, git email, git name, or known patterns
        if (
            login == "zw4315"
            or email == git_email
            or name_lower == git_name_lower
            or "edward" in name_lower
            or name == "zw4315"
        ):
            date_str = obj.get("date")
            if date_str:
                dates.append(date_str)
    return dates, len(dates)


# ---------------------------------------------------------------------------
# Aggregate commits across all repos
# ---------------------------------------------------------------------------
def aggregate_repo_daily(repo_daily):
    daily = {}
    repos = {}
    cutoff = datetime.now().date() - timedelta(weeks=WEEKS_TO_SHOW)
    for repo_name, date_counts in repo_daily.items():
        repo_total = 0
        for date_str, count in date_counts.items():
            date_obj = datetime.strptime(date_str, "%Y-%m-%d").date()
            if date_obj >= cutoff:
                daily[date_str] = daily.get(date_str, 0) + count
                repo_total += count
        if repo_total > 0:
            repos[repo_name] = repo_total
    repo_stats = sorted(repos.items(), key=lambda x: x[1], reverse=True)
    return daily, repo_stats


def get_all_commit_info():
    cache = load_daily_cache()

    # 同一天内直接返回缓存
    if cache and is_today_cache(cache):
        data = cache['data']
        return data['daily'], data['repos']

    repo_daily = {}
    complete_through = None
    if cache and 'data' in cache:
        repo_daily = cache['data'].get('repo_daily', {})
        complete_through = cache.get('complete_through')

    now = datetime.now()
    today = now.date()

    if complete_through:
        since_date = datetime.strptime(complete_through, "%Y-%m-%d").date() + timedelta(days=1)
    else:
        since_date = today - timedelta(weeks=WEEKS_TO_SHOW)

    since = datetime.combine(since_date, datetime.min.time()).strftime("%Y-%m-%dT00:00:00Z")
    until = now.strftime("%Y-%m-%dT23:59:59Z")
    git_name, git_email = get_git_identity()
    repos = get_all_repos()

    new_repo_daily = {}
    with ThreadPoolExecutor(max_workers=5) as executor:
        futures = {
            executor.submit(get_repo_commit_info, r['name'], since, until, git_name, git_email): r['name']
            for r in repos
        }
        for future in futures:
            repo_name = futures[future]
            dates, count = future.result()
            if count > 0:
                new_repo_daily[repo_name] = {}
                for date_str in dates:
                    new_repo_daily[repo_name][date_str] = new_repo_daily[repo_name].get(date_str, 0) + 1

    # 合并新数据（日期范围无重叠，因为 since_date > complete_through）
    for repo_name, date_counts in new_repo_daily.items():
        if repo_name not in repo_daily:
            repo_daily[repo_name] = {}
        for date_str, count in date_counts.items():
            repo_daily[repo_name][date_str] = count

    # 裁剪超出显示窗口的旧数据
    cutoff = today - timedelta(weeks=WEEKS_TO_SHOW)
    for repo_name in list(repo_daily.keys()):
        filtered = {
            d: c for d, c in repo_daily[repo_name].items()
            if datetime.strptime(d, "%Y-%m-%d").date() >= cutoff
        }
        if filtered:
            repo_daily[repo_name] = filtered
        else:
            del repo_daily[repo_name]

    daily_counts, repo_stats = aggregate_repo_daily(repo_daily)

    # 昨天的数据已完整（查询从昨天 00:00 开始）
    new_complete_through = (today - timedelta(days=1)).strftime("%Y-%m-%d")

    save_daily_cache({
        'repo_daily': repo_daily,
        'daily': daily_counts,
        'repos': repo_stats
    }, complete_through=new_complete_through)
    return daily_counts, repo_stats


# ---------------------------------------------------------------------------
# Build calendar structure from real daily commit counts
# ---------------------------------------------------------------------------
def build_calendar_from_daily(daily_counts, weeks=20):
    today = datetime.now().date()
    # Find the Sunday of the current week (week starts on Sunday)
    end_week_start = today - timedelta(days=(today.weekday() + 1) % 7)
    start_week_start = end_week_start - timedelta(weeks=weeks - 1)

    weeks_list = []
    current = start_week_start
    while current <= end_week_start:
        days = []
        for i in range(7):
            day = current + timedelta(days=i)
            date_str = day.strftime("%Y-%m-%d")
            count = daily_counts.get(date_str, 0)
            days.append({"date": date_str, "contributionCount": count})
        weeks_list.append({"contributionDays": days})
        current += timedelta(weeks=1)

    total = sum(daily_counts.values())
    return {
        "data": {
            "viewer": {
                "contributionsCollection": {
                    "contributionCalendar": {
                        "totalContributions": total,
                        "weeks": weeks_list
                    }
                }
            }
        }
    }


# ---------------------------------------------------------------------------
# Heatmap renderer
# ---------------------------------------------------------------------------
def generate_heatmap(data, weeks=None):
    calendar = data["data"]["viewer"]["contributionsCollection"]["contributionCalendar"]
    all_weeks = calendar["weeks"]
    recent_weeks = all_weeks[-weeks:] if weeks and len(all_weeks) > weeks else all_weeks

    levels = ["  ", "░░", "▒▒", "▓▓", "██"]
    day_labels = ["S", "M", "T", "W", "T", "F", "S"]
    lines = []

    non_zero_counts = []
    for week in recent_weeks:
        for day in week.get("contributionDays", []):
            count = day.get("contributionCount", 0)
            if count > 0:
                non_zero_counts.append(count)

    non_zero_counts.sort()

    def percentile(sorted_values, p):
        if not sorted_values:
            return 0
        idx = int((len(sorted_values) - 1) * p)
        return sorted_values[idx]

    q1 = percentile(non_zero_counts, 0.25)
    q2 = percentile(non_zero_counts, 0.50)
    q3 = percentile(non_zero_counts, 0.75)

    # Determine month boundaries: mark any week that contains day 1
    month_starts = []
    last_month_num = None
    for i, week in enumerate(recent_weeks):
        days = week.get("contributionDays", [])
        if not days:
            continue
        week_dates = [datetime.strptime(day["date"], "%Y-%m-%d") for day in days]

        mark_dt = None
        for dt in week_dates:
            if dt.day == 1:
                mark_dt = dt
                break
        # Fallback for the very first week if it doesn't contain day 1
        if mark_dt is None and i == 0:
            mark_dt = week_dates[0]

        if mark_dt is not None and mark_dt.month != last_month_num:
            month_starts.append((i, mark_dt.strftime("%b")))
            last_month_num = mark_dt.month

    # Month labels
    col_width = 3
    month_chars = [" "] * (len(recent_weeks) * col_width)
    for week_idx, month in month_starts:
        pos = week_idx * col_width + 1
        for offset, ch in enumerate(month[:3]):
            if pos + offset < len(month_chars):
                month_chars[pos + offset] = ch
    lines.append(("   " + "".join(month_chars)).rstrip())

    # Day rows
    month_start_set = {start for start, _ in month_starts[1:]}
    for day_idx in range(7):
        row = " " + day_labels[day_idx] + " "
        for week_idx, week in enumerate(recent_weeks):
            days = week["contributionDays"]
            separator = "│" if week_idx in month_start_set else " "
            if day_idx < len(days):
                count = days[day_idx]["contributionCount"]
                if count == 0:
                    cell = levels[0]
                elif count <= q1:
                    cell = levels[1]
                elif count <= q2:
                    cell = levels[2]
                elif count <= q3:
                    cell = levels[3]
                else:
                    cell = levels[4]
            else:
                cell = levels[0]
            row += separator + cell
        lines.append(row.rstrip())

    total = calendar.get("totalContributions", 0)
    lines.append("")
    lines.append("   Legend: ░ low  ▒ mid  ▓ high  █ peak")
    lines.append(f"   {total} commits in the last year")
    return [line.rstrip() for line in lines]


# ---------------------------------------------------------------------------
# Recently updated repos (for the lower section)
# ---------------------------------------------------------------------------
def run_gh_repos(limit=8):
    try:
        result = subprocess.run(
            [
                "gh",
                "repo",
                "list",
                "--limit",
                str(limit),
                "--json",
                "name,pushedAt,visibility",
                "--jq",
                ".[] | [.pushedAt, .name, .visibility] | @tsv",
            ],
            capture_output=True,
            text=True,
        )
    except FileNotFoundError:
        return []
    if result.returncode != 0:
        return []
    repos = []
    for line in result.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split("\t")
        if len(parts) >= 2:
            pushed_at = parts[0]
            name = parts[1]
            visibility = parts[2] if len(parts) > 2 else "public"
            try:
                dt = datetime.fromisoformat(pushed_at.replace("Z", "+00:00"))
                date_str = dt.strftime("%m-%d")
            except Exception:
                date_str = pushed_at[:10]
            repos.append((date_str, name, visibility))
    return repos


# ---------------------------------------------------------------------------
# GH availability check
# ---------------------------------------------------------------------------
def is_gh_available():
    # 先快速探测 gh 命令是否存在（避免 FileNotFoundError 慢路径）
    try:
        subprocess.run(
            ["gh", "--version"],
            capture_output=True, timeout=1
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return False

    # 再验证是否已登录（超时设短，不要阻塞 Vim 启动）
    try:
        result = subprocess.run(
            ["gh", "auth", "status"],
            capture_output=True, text=True, timeout=2
        )
        return result.returncode == 0
    except Exception:
        return False


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main():
    # Level 1: gh available → full GitHub dashboard
    if is_gh_available():
        output = []
        repo_stats = None
        daily_counts = None

        try:
            daily_counts, repo_stats = get_all_commit_info()
            total = sum(daily_counts.values())

            data = build_calendar_from_daily(daily_counts)
            output.append("  GitHub Contribution Heatmap")
            output.append("  (based on actual commits across all repos)")
            output.append("")
            output.extend(generate_heatmap(data))
            output.append("")
        except Exception as e:
            output.append("  Unable to fetch GitHub data")
            output.append(f"  Reason: {e}")

        # Build side-by-side sections
        left_lines = []
        right_lines = []

        if repo_stats:
            left_lines.append("Top 10 Active Repositories")
            left_lines.append("")
            for repo_name, count in repo_stats[:10]:
                left_lines.append(f"{repo_name}: {count} commits")

        repos = run_gh_repos()
        if repos:
            right_lines.append("Recently Updated Repositories")
            right_lines.append("")
            for date_str, name, visibility in repos:
                icon = "●" if visibility == "public" else "○"
                right_lines.append(f"{date_str} {icon} {name}")

        # If both sections exist, render side-by-side
        if left_lines and right_lines:
            left_prefixed = [f"   {line}" for line in left_lines]
            right_prefixed = [f"   {line}" for line in right_lines]
            left_width = max(len(line) for line in left_prefixed)
            max_rows = max(len(left_prefixed), len(right_prefixed))

            for i in range(max_rows):
                left = left_prefixed[i] if i < len(left_prefixed) else " " * left_width
                right = right_prefixed[i] if i < len(right_prefixed) else ""
                output.append(f"{left:<{left_width}}    {right}")
        else:
            # Fallback to original vertical layout
            if repo_stats:
                output.append("   Top 10 Active Repositories")
                output.append("")
                for repo_name, count in repo_stats[:10]:
                    output.append(f"   {repo_name}: {count} commits")
                output.append("")

            if repos:
                output.append("---REPOS---")
                output.append("  Recently Updated Repositories")
                output.append("")
                for date_str, name, visibility in repos:
                    icon = "●" if visibility == "public" else "○"
                    output.append(f"   {date_str} {icon} {name}")

        for line in output:
            print(line)
        return

    # Level 2: not gh, but inside a git repo → show local recent commits
    try:
        result = subprocess.run(
            ["git", "log", "--oneline", "-10", "--no-decorate"],
            capture_output=True, text=True, timeout=2
        )
        if result.returncode == 0 and result.stdout.strip():
            print("  GitHub Dashboard")
            print("  Run `gh auth login` to enable cross-repo heatmap")
            print("")
            print("  Recent commits (this repo)")
            for line in result.stdout.strip().split("\n")[:10]:
                print(f"  {line}")
            return
    except Exception:
        pass

    # Level 3: neither gh nor git → minimal welcome
    print("  GitHub Dashboard")
    print("  Run `gh auth login` to enable contribution heatmap")


if __name__ == "__main__":
    main()
