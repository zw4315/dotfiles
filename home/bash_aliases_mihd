#!/usr/bin/env bash
# Mihomo 代理管理 alias 和函数

# mihomo 代理
# mih  - 前台启动
# mihd - 后台守护进程管理
alias mih='mihomo -f "${HOME}/.config/mihomo/config.yaml"'

# mihd 守护进程管理函数
mihd() {
  local cmd="${1:-start}"
  local config_file work_dir pid_file log_file

  # 配置文件位置
  config_file="${HOME}/.config/mihomo/config.yaml"

  # 工作目录：统一放 ~/.local/share/mihomo（符合 XDG 规范）
  # geoip.metadb 等数据文件放这里，config.yaml 仍在 ~/.config/mihomo/
  work_dir="${HOME}/.local/share/mihomo"
  pid_file="${work_dir}/mihomo.pid"
  log_file="${work_dir}/mihomo.log"

  # 日志轮转函数
  _mihd_rotate_log() {
    local max_log_size=$((10 * 1024 * 1024))
    local max_log_lines=1000
    if [[ -f "$log_file" ]]; then
      local file_size
      file_size=$(stat -f%z "$log_file" 2>/dev/null || stat -c%s "$log_file" 2>/dev/null || echo 0)
      if [[ "$file_size" -gt "$max_log_size" ]]; then
        tail -n "$max_log_lines" "$log_file" > "${log_file}.tmp" 2>/dev/null && \
          mv "${log_file}.tmp" "$log_file" 2>/dev/null
      fi
    fi
  }

  case "$cmd" in
    start|"")
      if [[ -f "$pid_file" ]]; then
        local old_pid
        old_pid=$(cat "$pid_file")
        if kill -0 "$old_pid" 2>/dev/null; then
          echo "mihomo is already running (PID: $old_pid)"
          return 1
        else
          echo "Removing stale PID file (PID: $old_pid no longer exists)"
          rm -f "$pid_file"
        fi
      fi

      # 确保 geoip 数据库存在，避免启动死锁（mihomo 需要 geoip → 下载需要代理 → 代理没启动）
      local geoip_db="${work_dir}/geoip.metadb"
      local fallback_db="${HOME}/.config/mihomo/geoip.metadb"
      if [[ ! -f "$geoip_db" && -f "$fallback_db" ]]; then
        echo "Copying geoip.metadb to work directory..."
        cp "$fallback_db" "$geoip_db"
      fi
      if [[ ! -f "$geoip_db" ]]; then
        echo "Warning: geoip.metadb not found in ${work_dir}"
        echo "Mihomo may fail to start if your config uses GEOIP rules."
        echo "Consider downloading it manually or starting mihomo once without '-d' to let it download."
      fi

      mkdir -p "$work_dir"
      _mihd_rotate_log
      echo "Starting mihomo daemon..."
      nohup mihomo -f "$config_file" -d "$work_dir" >"$log_file" 2>&1 &
      echo $! > "$pid_file"
      echo "mihomo started (PID: $!)"
      echo "Log file: $log_file"
      ;;
    stop)
      if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
          kill "$pid" 2>/dev/null && echo "mihomo stopped (PID: $pid)"
        fi
        rm -f "$pid_file"
      fi
      # 额外清理任何残留的进程
      local pids
      pids=$(pgrep -x mihomo 2>/dev/null || true)
      if [[ -n "$pids" ]]; then
        echo "$pids" | xargs kill -9 2>/dev/null && echo "mihomo force stopped"
      elif [[ ! -f "$pid_file" ]]; then
        echo "mihomo is not running"
      fi
      ;;
    force|restart)
      # 强制重启：杀死所有进程 + 清理 pid 文件 + 重新启动
      echo "Force restarting mihomo..."
      # 1. 杀死所有 mihomo 进程
      pkill -9 mihomo 2>/dev/null || true
      # 2. 清理 pid 文件
      rm -f "$pid_file"
      # 3. 等待进程退出
      sleep 1
      # 4. 确保工作目录存在
      mkdir -p "$work_dir"
      # 5. 日志轮转
      _mihd_rotate_log
      # 6. 重新启动
      echo "Starting mihomo daemon..."
      nohup mihomo -f "$config_file" -d "$work_dir" >"$log_file" 2>&1 &
      echo $! > "$pid_file"
      echo "mihomo force restarted (PID: $!)"
      echo "Log file: $log_file"
      ;;
    st|status)
      if [[ -f "$pid_file" ]]; then
        local pid
        pid=$(cat "$pid_file")
        if kill -0 "$pid" 2>/dev/null; then
          echo "mihomo is running (PID: $pid)"
          echo "Config: $config_file"
          echo "Work dir: $work_dir"
          # 显示端口监听情况
          echo "Ports:"
          if command -v ss >/dev/null 2>&1; then
            ss -tln 2>/dev/null | grep -E ":7890|:7891|:9090" | head -3 || echo "  (no expected ports listening)"
          elif command -v netstat >/dev/null 2>&1; then
            netstat -tln 2>/dev/null | grep -E ":7890|:7891|:9090" | head -3 || echo "  (no expected ports listening)"
          else
            echo "  7890 (HTTP/SOCKS5 mixed)"
            echo "  9090 (Web controller)"
          fi
        else
          echo "mihomo is not running (stale PID file: $pid_file)"
          echo "Run 'mihd start' to restart, or 'mihd logs' to see why it crashed"
        fi
      else
        local pids
        pids=$(pgrep -x mihomo 2>/dev/null || true)
        if [[ -n "$pids" ]]; then
          echo "mihomo is running (PIDs: $pids) - no PID file found"
        else
          echo "mihomo is not running"
        fi
      fi
      ;;
    config|edit)
      local config_file="${HOME}/.config/mihomo/config.yaml"
      local sub_url="${2:-}"

      if [[ -n "$sub_url" ]]; then
        # 从订阅 URL 下载配置
        echo "Downloading config from subscription URL..."
        local tmp_file
        tmp_file="$(mktemp)"
        if ! curl -fsSL --connect-timeout 15 "$sub_url" -o "$tmp_file" 2>/dev/null; then
          echo "❌ Failed to download from: $sub_url"
          rm -f "$tmp_file"
          return 1
        fi

        # 检查内容是否像 clash/mihomo 配置
        local is_yaml=0
        if grep -qE '^proxies:|^proxy-groups:|^port:|^mixed-port:' "$tmp_file" 2>/dev/null; then
          is_yaml=1
        fi

        # 如果内容很短且看起来像 base64，尝试解码
        local file_size
        file_size=$(stat -f%z "$tmp_file" 2>/dev/null || stat -c%s "$tmp_file" 2>/dev/null || echo 0)
        if [[ "$is_yaml" -eq 0 && "$file_size" -lt 10240 ]]; then
          local decoded
          decoded="$(base64 -d "$tmp_file" 2>/dev/null || true)"
          if [[ -n "$decoded" ]] && echo "$decoded" | grep -qE '^(ss|vmess|trojan|vless)://'; then
            echo "⚠️  This URL returns raw subscription links (not a clash config)."
            echo "   You need a subconverter to convert it to clash format."
            echo "   Example: https://github.com/tindy2013/subconverter"
            rm -f "$tmp_file"
            return 1
          fi
        fi

        if [[ "$is_yaml" -eq 0 ]]; then
          echo "⚠️  Downloaded file doesn't look like a valid clash/mihomo config."
          echo "   Expected fields: proxies, proxy-groups, port, mixed-port"
          rm -f "$tmp_file"
          return 1
        fi

        # 备份旧配置
        if [[ -f "$config_file" ]]; then
          local bak_file="${config_file}.bak.$(date +%s)"
          cp "$config_file" "$bak_file"
          echo "💾 Old config backed up to: $bak_file"
        fi

        # 保存新配置，并适配本地环境
        cp "$tmp_file" "$config_file"
        rm -f "$tmp_file"

        # 自动修正关键字段以适配本地 mihd
        sed -i.bak "s|external-controller:.*|external-controller: '127.0.0.1:9090'|" "$config_file" 2>/dev/null || true
        # 如果同时存在 port 和 mixed-port 且相同，注释掉 port 避免冲突
        local mixed_port
        mixed_port=$(grep -E '^mixed-port:' "$config_file" | awk '{print $2}' | tr -d "'\"" | head -1)
        if [[ -n "$mixed_port" ]]; then
          sed -i.bak "/^port:.*${mixed_port}/d" "$config_file" 2>/dev/null || true
        fi
        rm -f "${config_file}.bak" 2>/dev/null || true

        echo "✅ Config saved to: $config_file"

        # 如果 mihomo 正在运行，重启它
        if [[ -f "$pid_file" ]] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
          echo "🔄 Restarting mihomo..."
          mihd force
        else
          echo "Run 'mihd start' to apply the new config."
        fi
        return 0
      fi

      # 无 URL 参数时，打开编辑器
      if [[ -f "$config_file" ]]; then
        ${EDITOR:-vim} "$config_file"
      else
        echo "Config not found: $config_file"
        return 1
      fi
      ;;
    logs)
      # 查看 mihomo 日志（默认 tail -n 50 -f）
      local lines="${2:-50}"
      if [[ ! "$lines" =~ ^[0-9]+$ ]]; then
        echo "Invalid lines count: $lines"
        echo "Usage: mihd logs [lines]"
        return 1
      fi

      if [[ -f "$log_file" ]]; then
        echo "Tailing $log_file (last $lines lines, Ctrl+C to exit)"
        tail -n "$lines" -f "$log_file"
      else
        echo "Log file not found: $log_file"
        echo "Start mihomo first with: mihd start"
        return 1
      fi
      ;;
    nodes|ls)
      # 列出所有可用节点（带编号，按延迟排序）
      local api_url="http://127.0.0.1:9090"
      local proxies
      proxies=$(curl -s "$api_url/proxies" 2>/dev/null)
      if [[ -z "$proxies" ]]; then
        echo "Failed to get nodes. Is mihomo running?"
        return 1
      fi
      echo "=== Available Nodes (sorted by delay, use 'mihd use <number>' to switch) ==="
      echo "$proxies" | python3 -c "
import sys, json, re
data = json.load(sys.stdin)

# 排除的信息节点关键词
SKIP_PATTERNS = [
    r'剩余流量', r'套餐到期', r'过滤', r'如遇', r'欢迎加入',
    r'永久地址', r'大陆访问', r'官方', r'Telegram', r'@',
    r'V2NY', r'V2NAIUN', r'更新订阅', r'群组', r'失效'
]

def is_real_node(name):
    '''判断是否是真正的代理节点（排除信息/提示节点）'''
    for pattern in SKIP_PATTERNS:
        if re.search(pattern, name):
            return False
    return True

# 收集所有真实节点
nodes = []
for name, info in data.get('proxies', {}).items():
    if info.get('type') in ['Vmess', 'Vless', 'Shadowsocks', 'Trojan', 'Socks5']:
        if not is_real_node(name):
            continue
        history = info.get('history', [{}])
        delay = history[-1].get('delay', 999999) if history else 999999
        nodes.append((name, delay))

# 按延迟排序（低的在前）
nodes.sort(key=lambda x: x[1])

# 打印
for idx, (name, delay) in enumerate(nodes, 1):
    delay_str = f'{delay}ms' if delay < 999999 else 'N/A'
    print(f\"  [{idx:2d}] {name:35s} (delay: {delay_str})\")
" 2>/dev/null || echo "$proxies" | grep -o '"name":"[^"]*"' | head -30
      ;;
    now|current)
      # 显示当前使用的节点
      local api_url="http://127.0.0.1:9090"
      curl -s "$api_url/proxies/🚀%20节点选择" 2>/dev/null | python3 -c "
import sys, json
data = json.load(sys.stdin)
now = data.get('now', 'N/A')
print(f'Current node: {now}')
print(f\"Use 'mihd nodes' to list all nodes\")
print(f\"Use 'mihd use <number>' to switch\")
" 2>/dev/null || echo "Failed to get current node. Is mihomo running?"
      ;;
    use)
      # 切换到指定节点（支持数字索引或名称）
      # mihd use 0 - 切换到自动选择模式
      local target="${2:-}"
      if [[ -z "$target" ]]; then
        echo "Usage: mihd use <number|auto>"
        echo "Example: mihd use 1    # 使用节点列表中的第1个"
        echo "         mihd use 0    # 使用自动选择（推荐）"
        echo "         mihd use auto # 同上"
        echo "Use 'mihd nodes' to see the list"
        return 1
      fi
      
      local api_url="http://127.0.0.1:9090"
      local node_name=""
      
      # 处理自动选择模式 (0 或 auto) —— 选择延迟最低且已测速（delay > 0）的节点
      if [[ "$target" == "0" ]] || [[ "$target" == "auto" ]]; then
        node_name=$(curl -s "$api_url/proxies" 2>/dev/null | python3 -c "
import sys, json

data = json.load(sys.stdin)

# 排除的信息节点关键词（与 nodes 命令保持一致）
SKIP_PATTERNS = [
    r'剩余流量', r'套餐到期', r'过滤', r'如遇', r'欢迎加入',
    r'永久地址', r'大陆访问', r'官方', r'Telegram', r'@',
    r'V2NY', r'V2NAIUN', r'更新订阅', r'群组', r'失效'
]

def is_real_node(name):
    for pattern in SKIP_PATTERNS:
        if pattern in name:
            return False
    return True

nodes = []
for name, info in data.get('proxies', {}).items():
    # 支持 Shadowsocks、Trojan、Vmess、Vless 等代理节点
    if info.get('type') in ['Shadowsocks', 'Vmess', 'Vless', 'Trojan', 'Socks5']:
        if not is_real_node(name):
            continue
        history = info.get('history', [])
        delay = history[-1].get('delay', 0) if history else 0
        # 只取已测速（delay > 0）的节点
        if delay > 0:
            nodes.append((name, delay))

# 按延迟排序（低的在前）
nodes.sort(key=lambda x: x[1])

if nodes:
    print(nodes[0][0])
else:
    print('NO_NODE')
" 2>/dev/null)
        if [[ "$node_name" == "NO_NODE" ]] || [[ -z "$node_name" ]]; then
          echo "❌ No available node with latency data. Run 'mihd nodes' to check."
          return 1
        fi
        echo "🔄 Auto-selecting lowest latency node: $node_name"
      # 如果是数字（非0），获取对应节点名称
      elif [[ "$target" =~ ^[0-9]+$ ]]; then
        node_name=$(curl -s "$api_url/proxies" 2>/dev/null | python3 -c "
import sys, json, re
data = json.load(sys.stdin)

# 排除的信息节点关键词（与 nodes 命令保持一致）
SKIP_PATTERNS = [
    r'剩余流量', r'套餐到期', r'过滤', r'如遇', r'欢迎加入',
    r'永久地址', r'大陆访问', r'官方', r'Telegram', r'@',
    r'V2NY', r'V2NAIUN', r'更新订阅', r'群组', r'失效'
]

def is_real_node(name):
    for pattern in SKIP_PATTERNS:
        if re.search(pattern, name):
            return False
    return True

nodes = []
for name, info in data.get('proxies', {}).items():
    if info.get('type') in ['Vmess', 'Vless', 'Shadowsocks', 'Trojan', 'Socks5']:
        if not is_real_node(name):
            continue
        history = info.get('history', [{}])
        delay = history[-1].get('delay', 999999) if history else 999999
        nodes.append((name, delay))

# 按延迟排序（与 nodes 命令保持一致）
nodes.sort(key=lambda x: x[1])

idx = int(sys.argv[1]) - 1
if 0 <= idx < len(nodes):
    print(nodes[idx][0])
else:
    print('INVALID_INDEX')
" "$target" 2>/dev/null)
        if [[ "$node_name" == "INVALID_INDEX" ]] || [[ -z "$node_name" ]]; then
          echo "Invalid node number: $target"
          echo "Use 'mihd nodes' to see available nodes"
          return 1
        fi
      else
        node_name="$target"
      fi
      
      # 切换节点
      local response
      response=$(curl -s -X PUT "$api_url/proxies/🚀%20节点选择" \
        -H "Content-Type: application/json" \
        -d "{\"name\":\"$node_name\"}" 2>/dev/null)
      if [[ $? -eq 0 ]]; then
        echo "Switched to: $node_name"
      else
        echo "Failed to switch node. Is mihomo running?"
        return 1
      fi
      ;;
    *)
      echo "Usage: mihd {start|stop|force|status|logs|config|nodes|now|use}"
      echo "  start        - Start mihomo daemon (default)"
      echo "  stop         - Stop mihomo daemon"
      echo "  force        - Force kill and restart (fix stuck issues)"
      echo "  status       - Check mihomo status"
      echo "  logs         - Tail mihomo logs"
      echo "  config       - Edit config or download from URL"
      echo "  nodes        - List all available nodes"
      echo "  now          - Show current node"
      echo "  use <n|0>    - Switch to node n, or 0/auto for auto-select"
      echo ""
      echo "For proxy management, use: proxy tunnel <jump|off>  or  proxy env <jump|clash|off>"
      ;;
  esac
}
