#!/bin/bash

SRC="$HOME/gdshare"
DEST="gdrive:gdshare"

echo "🔄 Bisyncing $SRC <-> $DEST ..."

# For first run, use: ./sync_to_gdrive --resync
rclone bisync "$SRC" "$DEST" \
  --exclude ".git/**" --exclude "*.tmp" \
  --max-delete 50 \
  --conflict-resolve newer \
  --create-empty-src-dirs \
  --resilient \
  -P --stats=10s --stats-one-line \
  "$@"

echo "✅ Bisync done."
