#!/usr/bin/env bash
set -euo pipefail

die() { printf 'ERROR: %s\n' "$*" >&2; exit 1; }

usage() {
  cat <<'EOF'
Usage:
  proxy env <jump|clash|off>      Print shell export/unset code
  proxy tunnel <jump|off>         Manage SSH tunnel
  proxy status                    Show current proxy status
  proxy list                      List available proxy profiles
  proxy toggle-env                Toggle between off/jump/clash

Examples:
  eval "$(proxy env jump)"        # Enable jump proxy in current shell
  eval "$(proxy env off)"         # Disable proxy in current shell
  proxy tunnel jump               # Start SSH tunnel
  proxy tunnel off                # Stop SSH tunnel
EOF
}

is_wsl() { grep -qi microsoft /proc/version 2>/dev/null; }

is_macos() { [[ "$(uname)" == "Darwin" ]]; }

wsl_host_ip() {
  local ip=""
  ip="$(ip route 2>/dev/null | awk '/^default/ {print $3; exit}' || true)"
  [[ -n "$ip" ]] || ip="$(grep -m1 nameserver /etc/resolv.conf 2>/dev/null | awk '{print $2}' || true)"
  [[ -n "$ip" ]] || ip="127.0.0.1"
  printf '%s' "$ip"
}

proxy_url_jump() {
  printf '%s' "${PROXY_URL_JUMP:-http://127.0.0.1:8888}"
}

proxy_url_clash() {
  local host="${PROXY_CLASH_HOST:-}"
  local port="${PROXY_CLASH_PORT:-7890}"

  if [[ -z "$host" ]]; then
    if is_wsl; then
      host="$(wsl_host_ip)"
    else
      host="127.0.0.1"
    fi
  fi

  printf 'http://%s:%s' "$host" "$port"
}

cmd_list() {
  printf 'Available proxy profiles:\n'
  printf '  %-6s %s\n' jump "$(proxy_url_jump)"
  printf '  %-6s %s\n' clash "$(proxy_url_clash)"
  printf 'Current: %s\n' "${PROXY_MODE:-off}"
}

cmd_status() {
  printf 'PROXY_MODE=%s\n' "${PROXY_MODE:-off}"
  printf 'http_proxy=%s\n' "${http_proxy:-}"
  printf 'https_proxy=%s\n' "${https_proxy:-}"
  printf 'all_proxy=%s\n' "${all_proxy:-}"
  printf 'no_proxy=%s\n' "${no_proxy:-}"
}

cmd_env() {
  local name="${1:-}"
  if [[ -z "$name" || "$name" == "off" ]]; then
    cat <<'EOF'
unset http_proxy https_proxy all_proxy no_proxy
export PROXY_MODE="off"
EOF
    if is_macos; then
      local svc
      while IFS= read -r svc; do
        [[ "$svc" == \** ]] && continue
        printf 'networksetup -setwebproxystate %q off 2>/dev/null || true\n' "$svc"
        printf 'networksetup -setsecurewebproxystate %q off 2>/dev/null || true\n' "$svc"
      done < <(networksetup -listallnetworkservices 2>/dev/null | tail -n +2)
    fi
    return 0
  fi

  local url
  case "$name" in
    jump) url="$(proxy_url_jump)" ;;
    clash) url="$(proxy_url_clash)" ;;
    *) usage >&2; die "Unknown env profile: '$name'. Use: jump, clash, off" ;;
  esac

  printf 'export http_proxy=%q\n' "$url"
  printf 'export https_proxy=%q\n' "$url"
  printf 'export all_proxy=%q\n' "$url"
  printf 'export no_proxy=%q\n' 'localhost,127.0.0.1,::1'
  printf 'export PROXY_MODE=%q\n' "$name"
}

_tunnel_jump() {
  if nc -z -w 1 127.0.0.1 8888 2>/dev/null; then
    return 0
  fi

  if pgrep -f "ssh.*-L.*8888:127.0.0.1:8888.*jump" >/dev/null 2>&1; then
    local n=0
    while ! nc -z -w 1 127.0.0.1 8888 2>/dev/null && [[ $n -lt 10 ]]; do
      sleep 0.5
      ((n++))
    done
    return 0
  fi

  ssh -f -N jump
}

_tunnel_off() {
  local pids
  pids=$(pgrep -f "ssh.*-L.*8888:127.0.0.1:8888.*jump" 2>/dev/null || true)
  if [[ -n "$pids" ]]; then
    echo "$pids" | xargs kill 2>/dev/null
    echo "[*] SSH tunnel stopped"
  else
    echo "[*] No SSH tunnel running"
  fi
}

cmd_tunnel() {
  local name="${1:-}"
  case "$name" in
    jump) _tunnel_jump ;;
    off)  _tunnel_off ;;
    *) usage >&2; die "Unknown tunnel action: '$name'. Use: jump, off" ;;
  esac
}

cmd_toggle_env() {
  local cur="${PROXY_MODE:-off}"
  case "$cur" in
    off|"") cmd_env jump ;;
    jump) cmd_env clash ;;
    clash) cmd_env off ;;
    *) cmd_env off ;;
  esac
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    -h|--help|"") usage; exit 0 ;;
    list) shift; cmd_list ;;
    status) shift; cmd_status ;;
    env) shift; cmd_env "${1:-}" ;;
    tunnel) shift; cmd_tunnel "${1:-}" ;;
    toggle-env) shift; cmd_toggle_env ;;
    *) usage >&2; die "Unknown command: '$cmd'" ;;
  esac
}

main "$@"
